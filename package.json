{
  "name": "openclaw-tool-compressor",
  "version": "0.3.4",
  "description": "Tool definition compression for OpenAI-compatible LLM APIs. Replaces N tool definitions with 2 meta-tools (search_tools, call_tool) to reduce context window overhead by 70-97%.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw-tool-compressor": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "tool-compression",
    "context-optimization",
    "token-reduction",
    "llm",
    "openai",
    "proxy",
    "agent"
  ],
  "author": "Wanis Elabbar <70503629+elabbarw@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elabbarw/openclaw-tool-compressor"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
